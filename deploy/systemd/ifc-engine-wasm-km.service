[Unit]
Description=IFC Engine WASM KM Vite dev server
After=network.target

[Service]
Type=simple
User=maks
WorkingDirectory=/home/maks/projects/ifc-engine-wasm-km
Environment=NODE_ENV=development
Environment=PORT=5173
Environment=KM_ALLOWED_HOSTS=dev.lab-tim.ru,127.0.0.1,localhost
ExecStart=/home/maks/.hermes/node/bin/node scripts/dev-server.mjs
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
