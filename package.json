{
  "name": "ifc-wasm-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/copy-web-ifc.mjs",
    "dev": "vite --host 127.0.0.1",
    "dev:node": "node scripts/dev-server.mjs",
    "build": "tsc --noEmit && vite build",
    "test": "node --test tests/**/*.test.mjs tests/*.test.mjs",
    "test:performance": "node --test tests/performance/*.test.mjs tests/storage/model-cache.test.mjs",
    "smoke:regression": "node scripts/smoke-regression.mjs --dist dist",
    "predeploy:check": "node scripts/predeploy-check.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@thatopen/components": "3.4.6",
    "@thatopen/components-front": "3.4.3",
    "@thatopen/fragments": "3.4.5",
    "@thatopen/ui": "3.4.1",
    "@thatopen/ui-obc": "3.4.2",
    "camera-controls": "^3.1.2",
    "three": "0.184.0",
    "web-ifc": "0.0.77"
  },
  "devDependencies": {
    "@types/three": "0.184.0",
    "typescript": "^5.4.2",
    "vite": "^5.1.6"
  }
}
